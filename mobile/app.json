{
  "expo": {
    "name": "furnigo",
    "slug": "furnigo",
    "owner": "donodevweb",
    "scheme": "furnigo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.donodevweb.furnigo",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "furnigo"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf97514f-73e3-4404-ae0f-4b7c474ec53e"
      }
    }
  }
}
